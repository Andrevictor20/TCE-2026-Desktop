{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Estudos TCE-MA 2026",
  "version": "0.1.0",
  "identifier": "com.tce-ma-2026.cargo15",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Estudos TCE-MA 2026 — Auditor TI (Cargo 15)",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Planejamento de estudos - Auditor TI (Cargo 15) - TCE/MA 2026",
    "longDescription": "Aplicativo desktop para organização e planejamento de estudos para o concurso do Tribunal de Contas do Estado do Maranhão (TCE/MA) — Edital nº 1/2026, Cargo 15: Auditor Estadual de Controle Externo, Especialidade Tecnologia da Informação.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "rpm": {
        "release": "1"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:study.db"
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1QzlEQjhGNUJEOTFEMDcKUldRSEhkbGJqOXZKbGY2cVZ1K0c5YWVlb0lKZWVaMWQ0MVVjaXd4RzBUSFlkVDhyQ1A4MlZjaS8K",
      "endpoints": [
        "https://github.com/Andrevictor20/TCE-2026-Desktop/releases/latest/download/updater.json"
      ]
    }
  }
}
